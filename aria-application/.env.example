# ARIA Application — Environment Template
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to Git — it is excluded by .gitignore.

# ═══════════════════════════════════════════════════════════════════════════════
# Core Backend
# ═══════════════════════════════════════════════════════════════════════════════
BACKEND_PORT=8001
BACKEND_URL=http://localhost:8001
SECRET_KEY=change-me-to-a-long-random-string

# ═══════════════════════════════════════════════════════════════════════════════
# Elasticsearch
# ═══════════════════════════════════════════════════════════════════════════════
ELASTICSEARCH_URL=https://193.95.30.97:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=your-elastic-password
ELASTICSEARCH_USE_SSL=false

# ═══════════════════════════════════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# AI / LLM
# ═══════════════════════════════════════════════════════════════════════════════
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_HOST=http://193.95.30.97:11434
OLLAMA_TIMEOUT=120
LLM_ENABLED=true
LLM_FALLBACK_TO_PYRCA=true

# Optional API keys for cloud providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=
# NVIDIA_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Ansible / SSH Remediation
# ═══════════════════════════════════════════════════════════════════════════════
ANSIBLE_ENABLED=true
ANSIBLE_REMOTE_HOST=your-target-vm-ip
ANSIBLE_REMOTE_USER=your-ssh-user
ANSIBLE_SSH_PORT=22
# Use either a key or a password (key recommended)
# ANSIBLE_SSH_KEY=/app/data/your-key.pem
# ANSIBLE_SSH_PASSWORD=your-ssh-password
ANSIBLE_TIMEOUT=300
ANSIBLE_BECOME_METHOD=sudo
# ANSIBLE_BECOME_PASSWORD=your-sudo-password

# ═══════════════════════════════════════════════════════════════════════════════
# CORS / Security
# ═══════════════════════════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:3001

# Comma-separated admin usernames and a shared secret for admin endpoints
ARIA_ADMIN_USERS=admin
ARIA_ADMIN_SECRET=another-long-random-string

# ═══════════════════════════════════════════════════════════════════════════════
# Rate Limiting
# ═══════════════════════════════════════════════════════════════════════════════
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_SENSITIVE_MAX_REQUESTS=10

# ═══════════════════════════════════════════════════════════════════════════════
# Auto-Approval
# ═══════════════════════════════════════════════════════════════════════════════
AUTO_APPROVE_ENABLED=false
AUTO_APPROVE_METHOD=hybrid
AUTO_APPROVE_SEVERITIES=low
AUTO_APPROVE_BLOCK_SEVERITIES=critical

# ═══════════════════════════════════════════════════════════════════════════════
# Notifications
# ═══════════════════════════════════════════════════════════════════════════════
# SLACK_WEBHOOK_URL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_FROM=
# SMTP_USER=
# SMTP_PASSWORD=
# NOTIFICATION_EMAIL=
# NOTIFICATION_EMAIL_TO=

# ═══════════════════════════════════════════════════════════════════════════════
# Performance Monitoring
# ═══════════════════════════════════════════════════════════════════════════════
PERFORMANCE_ENABLED=true
PERFORMANCE_POLL_INTERVAL=15
PERFORMANCE_CPU_WARNING=70
PERFORMANCE_CPU_CRITICAL=90
PERFORMANCE_MEMORY_WARNING=75
PERFORMANCE_MEMORY_CRITICAL=85
PERFORMANCE_ANOMALY_DETECTION=true

# ═══════════════════════════════════════════════════════════════════════════════
# Paths / State
# ═══════════════════════════════════════════════════════════════════════════════
DB_PATH=data/investigations.db
PLAYBOOK_DIR=data/playbooks
CURSOR_DIR=data/cursors
SEEN_IDS_DIR=data/seen_ids
BACKUP_DIR=data/backups

# ═══════════════════════════════════════════════════════════════════════════════
# Advanced / Optional
# ═══════════════════════════════════════════════════════════════════════════════
LOCAL_ONLY_MODE=false
INCIDENT_WATCHER_INTERVAL=15
INCIDENT_CORRELATION_INTERVAL=30
